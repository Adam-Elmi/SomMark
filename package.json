{
	"name": "sommark",
	"version": "4.0.3",
	"description": "SomMark is a declarative, extensible markup language for structured content that can be converted to HTML, Markdown, MDX, JSON, XML, and more.",
	"main": "index.js",
	"files": [
		"index.js",
		"core/",
		"mappers/",
		"helpers/",
		"formatter/",
		"constants/",
		"cli/",
		"assets/",
		"grammar.ebnf",
		"README.md",
		"LICENSE"
	],
	"directories": {
		"test": "tests"
	},
	"type": "module",
	"exports": {
		"import": "./index.js"
	},
	"scripts": {
		"test": "vitest",
		"test:run": "vitest run --pool=forks --maxWorkers=1",
		"test:watch": "vitest watch",
		"test:html": "vitest run tests/html"
	},
	"bin": {
		"sommark": "cli/cli.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Adam-Elmi/SomMark.git"
	},
	"keywords": [
		"language",
		"markup",
		"markup-language",
		"documentation",
		"parser",
		"transpiler",
		"html",
		"markdown",
		"mdx",
		"xml",
		"json",
		"dsl",
		"mapper",
		"mapping"
	],
	"author": "Adam Elmi",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Adam-Elmi/SomMark/issues"
	},
	"homepage": "https://github.com/Adam-Elmi/SomMark#readme",
	"devDependencies": {
		"@mdx-js/mdx": "^3.1.1",
		"fast-xml-parser": "^5.5.11",
		"jsdom": "^29.0.2",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"vitest": "^4.0.16"
	}
}
