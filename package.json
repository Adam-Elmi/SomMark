{
	"name": "sommark",
	"version": "5.2.0",
	"description": "SomMark is a template language that compiles to multiple output formats — HTML, JSON, YAML, TOML, CSV, Markdown, XML, and more.",
	"main": "index.js",
	"files": [
		"index.js",
		"index.browser.js",
		"index.shared.js",
		"async-hooks.js",
		"vite.js",
		"rollup.js",
		"esbuild.js",
		"core/",
		"mappers/",
		"helpers/",
		"formatter/",
		"constants/",
		"cli/",
		"assets/",
		"dist/",
		"grammar.ebnf",
		"README.md",
		"LICENSE"
	],
	"directories": {
		"test": "tests"
	},
	"type": "module",
	"exports": {
		".": "./index.js",
		"./browser": "./index.browser.js",
		"./vite": "./vite.js",
		"./rollup": "./rollup.js",
		"./esbuild": "./esbuild.js"
	},
	"scripts": {
		"test": "vitest",
		"test:run": "vitest run --pool=forks --maxWorkers=1",
		"test:watch": "vitest watch",
		"test:html": "vitest run tests/html",
		"build:pathe": "node scripts/build-pathe.js",
		"build:browser": "rollup -c rollup.browser.config.js",
		"build:lite": "rollup -c rollup.browser.lite.config.js",
		"build:lexer": "rollup -c rollup.browser.lexer.config.js",
		"build:parser": "rollup -c rollup.browser.parser.config.js",
		"build:all": "npm run build:pathe && npm run build:browser && npm run build:lite && npm run build:lexer && npm run build:parser",
		"prepublishOnly": "npm run build:all"
	},
	"bin": {
		"sommark": "cli/cli.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Adam-Elmi/SomMark.git"
	},
	"keywords": [
		"language",
		"markup",
		"markup-language",
		"documentation",
		"parser",
		"transpiler",
		"html",
		"markdown",
		"mdx",
		"xml",
		"json",
		"dsl",
		"mapper",
		"mapping"
	],
	"author": "Adam Elmi",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Adam-Elmi/SomMark/issues"
	},
	"homepage": "https://github.com/Adam-Elmi/SomMark#readme",
	"devDependencies": {
		"@mdx-js/mdx": "^3.1.1",
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"fast-xml-parser": "^5.5.11",
		"isomorphic-dompurify": "^3.14.0",
		"js-yaml": "^5.0.0",
		"jsdom": "^29.0.2",
		"papaparse": "^5.5.4",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"rollup": "^4.61.1",
		"smol-toml": "^1.7.0",
		"vitest": "^4.0.16"
	},
	"dependencies": {
		"acorn": "^8.15.0",
		"pathe": "^2.0.3",
		"quickjs-emscripten": "^0.32.0"
	}
}
