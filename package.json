{
	"name": "sommark",
	"version": "3.0.0",
	"description": "SomMark is a declarative, extensible markup language for structured content that can be converted to HTML, Markdown, MDX, JSON, and more.",
	"main": "index.js",
	"directories": {
		"test": "tests"
	},
	"type": "module",
	"exports": {
		"import": "./index.js"
	},
	"scripts": {
		"test": "vitest",
		"test:run": "vitest run",
		"test:watch": "vitest watch",
		"release": "bash scripts/release.sh",
		"publish": "bash scripts/publish.sh"
	},
	"bin": {
		"sommark": "cli/cli.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Adam-Elmi/SomMark.git"
	},
	"keywords": [
		"language",
		"markup",
		"markup-language",
		"documentation",
		"parser",
		"transpiler",
		"html",
		"markdown",
		"mdx",
		"dsl",
		"mapper",
		"mapping"
	],
	"author": "Adam Elmi",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Adam-Elmi/SomMark/issues"
	},
	"homepage": "https://github.com/Adam-Elmi/SomMark#readme",
	"devDependencies": {
		"vitest": "^4.0.16"
	}
}