[str = "name", "myproject" !]
[str = "version", "1.0.0" !]

[array = "features"]
  [for-each = ${ packages }$, as: "p"]
    [str = ${ p.name }$ !]
  [end]
[end]

[table = "metadata"]
  [for-each = ${ packages }$, as: "p"]
    [str = ${ p.name }$, ${ p.version }$ !]
  [end]
[end]

[for-each = ${ packages }$, as: "p"]
  [array-table = "dependencies"]
    [str = "name", ${ p.name }$ !]
    [str = "version", ${ p.version }$ !]
    [bool = "optional", ${ p.optional }$ !]
    [array = "tags"]
      [str = "dep" !]
      [str = ${ p.name }$ !]
    [end]
  [end]
[end]
