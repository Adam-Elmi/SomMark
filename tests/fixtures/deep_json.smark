[Object]
  [string = key: "project"]SomMark[end]
  [Array = "versions"]
    [Object]
      [string = key: "tag"]v5[end]
      [bool = key: "stable", value: "true" !]
      [Array = "targets"]
        [string = "browser" !]
        [string = "node" !]
      [end]
    [end]
    [Object]
      [string = key: "tag"]v4[end]
      [bool = key: "stable", value: "false" !]
      [Array = "targets"]
        [string = "node" !]
      [end]
    [end]
  [end]
  [Array = "deps"]
    [for-each = ${ packages }$, as: "p"]
      [Object]
        [string = key: "name", value: ${ p.name }$ !]
        [string = key: "version", value: ${ p.version }$ !]
        [bool = key: "optional", value: ${ p.optional }$ !]
      [end]
    [end]
  [end]
[end]
