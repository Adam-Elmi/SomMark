[Table]
  [header]
    [row]
      [cell]Name[end]
      [cell]Age[end]
      [cell]City[end]
    [end]
  [end]
  [body]
    [for-each = ${ users }$, as: "u"]
      [row]
        [cell]${ u.name }$[end]
        [cell]${ u.age }$[end]
        [cell]${ u.city }$[end]
      [end]
    [end]
  [end]
[end]
